{
  "name": "psteam",
  "version": "1.0.0",
  "description": "PlayStation-style trophy overlay for Steam achievements",
  "main": "out/main/index.js",
  "type": "module",
  "author": "PSteam",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "release": "npm run dist"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "mongodb": "^6.12.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.6.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.0",
    "electron-builder": "^26.0.12",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.psteam.desktop",
    "productName": "PSteam",
    "copyright": "Copyright © 2026 PSteam",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "resources/**/*"
    ],
    "asar": true,
    "win": {
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.games",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Game",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "publish": null
  }
}
